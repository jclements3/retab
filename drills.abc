[V:V2] "_8"C,2 E,2 G,2 C2 | "_8"D,2 F,2 A,2 D2 | "_8"E,2 G,2 B,2 E2 | "_8"F,2 A,2 C2 F2 | "_8"G,2 B,2 D2 G2 | "_8"A,2 C2 E2 A2 | "_8"B,2 D2 F2 B2 | "_8"C,2 E,2 G,2 C2 |]

